{
  "name": "familie-ba-soknad",
  "type": "module",
  "scripts": {
    "start:dev": "yarn clean && concurrently \"yarn:dev:*\"",
    "dev:server": "yarn build:backend && NODE_ENV=development node dist/backend/server.js",
    "dev:frontend": "vite",
    "dev": "concurrently \"yarn:dev:server\" \"yarn:dev:frontend\"",
    "build": "yarn build:frontend && yarn build:backend",
    "build:frontend": "vite build",
    "build:backend": "tsc -p src/backend/tsconfig.json && node scripts/prune-backend-node-modules.mjs",
    "clean": "rm -rf dist",
    "test": "vitest",
    "lint": "eslint './src/**/*.{js,ts,tsx}'",
    "lint:fix": "eslint './src/**/*.{js,ts,tsx}' --fix",
    "prettier": "prettier --check './src/**/*.{js,jsx,ts,tsx,json,css}'",
    "prettier:fix": "prettier --write './src/**/*.{js,jsx,ts,tsx,json,css}'",
    "typecheck": "tsc --noEmit -p src/backend/tsconfig.json && tsc --noEmit -p src/frontend/tsconfig.json",
    "validate": "yarn typecheck && yarn lint && yarn prettier",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,css}": [
      "prettier --write",
      "eslint --fix src/ --max-warnings=76"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "2.8.2",
    "@navikt/aksel-icons": "8.14.0",
    "@navikt/ds-css": "8.14.0",
    "@navikt/ds-react": "8.14.0",
    "@navikt/familie-form-elements": "22.0.1",
    "@navikt/familie-http": "8.0.22",
    "@navikt/familie-logging": "7.0.7",
    "@navikt/familie-skjema": "8.2.48",
    "@navikt/familie-typer": "8.0.5",
    "@navikt/fnrvalidator": "2.2.1",
    "@navikt/nav-dekoratoren-moduler": "4.2.2",
    "@navikt/oasis": "4.1.4",
    "@portabletext/react": "6.2.0",
    "@portabletext/toolkit": "5.0.2",
    "@sanity/client": "7.23.0",
    "@sentry/react": "10.64.0",
    "axios": "1.18.1",
    "classnames": "2.5.1",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "http-proxy-middleware": "4.1.1",
    "i18n-iso-countries": "7.14.0",
    "mustache-express": "1.3.2",
    "ramda": "0.32.0",
    "react": "19.2.7",
    "react-cookie": "8.1.2",
    "react-dom": "19.2.7",
    "react-router": "8.0.1",
    "styled-components": "6.4.3",
    "unleash-client": "6.11.1",
    "uuid": "14.0.1",
    "xss": "1.0.15"
  },
  "devDependencies": {
    "@axe-core/react": "4.12.1",
    "@eslint/js": "10.0.1",
    "@portabletext/types": "4.0.2",
    "@sentry/vite-plugin": "5.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/express": "5.0.6",
    "@types/http-proxy": "1.17.17",
    "@types/mustache-express": "1.2.5",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vercel/nft": "1.10.2",
    "@vitejs/plugin-react": "6.0.4",
    "concurrently": "10.0.3",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "msw": "2.14.6",
    "prettier": "3.8.4",
    "ts-essentials": "10.2.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.1.5",
    "vitest": "4.1.9",
    "vitest-mock-extended": "4.0.0"
  }
}
